<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent">

	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/rv_items"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_marginBottom="10dp"
		android:scrollbarStyle="insideOverlay"
		android:scrollbars="vertical"
		app:layoutManager="LinearLayoutManager"
		app:layout_constraintBottom_toBottomOf="@+id/seek_bar"
		app:layout_constraintLeft_toLeftOf="parent"
		app:layout_constraintRight_toRightOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		app:layout_goneMarginBottom="0dp"/>

	<androidx.constraintlayout.widget.Group
		android:id="@+id/group_player"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		app:constraint_referenced_ids="v_left,v_right,seek_bar,btn_previous,btn_play,btn_next"/>

	<androidx.appcompat.widget.AppCompatSeekBar
		android:id="@+id/seek_bar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginBottom="12dp"
		android:layout_marginLeft="-10dp"
		android:layout_marginRight="-10dp"
		android:progress="10"
		android:progressDrawable="@drawable/progress_yellow"
		app:layout_constraintBottom_toTopOf="@+id/btn_play"/>

	<com.ironwaterstudio.controls.ImageViewEx
		android:id="@+id/btn_previous"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:clickable="true"
		android:foreground="@drawable/circle_selector"
		android:padding="16dp"
		app:layout_constraintHorizontal_chainStyle="packed"
		app:layout_constraintLeft_toLeftOf="parent"
		app:layout_constraintRight_toLeftOf="@+id/btn_play"
		app:layout_constraintTop_toTopOf="@+id/btn_play"
		app:srcMain="@drawable/icn_last"/>

	<com.ironwaterstudio.controls.ImageViewEx
		android:id="@+id/btn_play"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginBottom="11dp"
		android:layout_marginLeft="20dp"
		android:clickable="true"
		android:foreground="@drawable/circle_selector"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintLeft_toRightOf="@+id/btn_previous"
		app:layout_constraintRight_toLeftOf="@+id/btn_next"
		app:srcMain="@drawable/icn_play"/>

	<com.ironwaterstudio.controls.ImageViewEx
		android:id="@+id/btn_next"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginLeft="20dp"
		android:clickable="true"
		android:foreground="@drawable/circle_selector"
		android:padding="16dp"
		app:layout_constraintLeft_toRightOf="@+id/btn_play"
		app:layout_constraintRight_toRightOf="parent"
		app:layout_constraintTop_toTopOf="@+id/btn_play"
		app:srcMain="@drawable/icn_next"/>
</androidx.constraintlayout.widget.ConstraintLayout>