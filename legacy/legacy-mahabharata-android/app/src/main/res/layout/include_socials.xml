<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="fill_horizontal"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/iv_social_donate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|center_vertical"
        android:layout_weight="1"
        app:srcCompat="@drawable/ic_social_give" />

    <ImageView
        android:id="@+id/iv_social_shop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|center_vertical"
        android:layout_weight="1"
        app:srcCompat="@drawable/ic_social_shop" />

    <ImageView
        android:id="@+id/iv_social_patreon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|center_vertical"
        android:layout_weight="1"
        app:srcCompat="@drawable/ic_social_patreon" />

    <ImageView
        android:id="@+id/iv_social_instagram"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_gravity="center|center_vertical"
        android:layout_weight="1"
        app:srcCompat="@drawable/ic_social_instagram" />

    <ImageView
        android:id="@+id/iv_social_facebook"
        android:layout_width="wrap_content"

        android:layout_height="wrap_content"
        android:layout_gravity="center|center_vertical"
        android:layout_weight="1"
        app:srcCompat="@drawable/ic_social_facebook" />

    <ImageView
        android:id="@+id/iv_social_youtube"
        android:layout_width="wrap_content"

        android:layout_height="wrap_content"
        android:layout_gravity="center|center_vertical"
        android:layout_weight="1"
        app:srcCompat="@drawable/ic_social_youtube" />
</LinearLayout>